---
// Navbar.astro
import { Image } from 'astro:assets';
import logo from '../assets/logo.jpg';

const links = [
  { name: 'Home', href: '/' },
  { name: 'Pricing', href: '/pricing' },
  { name: 'About', href: '/about' },
  { name: 'Book Now', href: '/book-now' },
  { name: 'My Cart', href: '/cart' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 backdrop-blur-md bg-white/70 border-b border-black/5">
  <div class="max-w-7xl mx-auto px-6 h-32 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <a href="/" class="block group">
        <Image 
          src={logo} 
          alt="Omega Detailing Logo" 
          class="h-20 w-auto transition-transform duration-500 group-hover:scale-105" 
          loading="eager"
        />
      </a>
    </div>

    {/* Desktop Navigation */}
    <div class="hidden md:flex items-center gap-10">
      {links.map((link) => (
        <a 
          href={link.href} 
          class="text-xs uppercase tracking-[0.2em] text-neutral-600 hover:text-blue-600 transition-all duration-300 font-bold"
        >
          {link.name}
        </a>
      ))}
    </div>

    {/* Mobile Menu Toggle */}
    <div class="md:hidden flex">
      <button id="mobile-menu-button" class="text-black p-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>
  
  {/* Mobile Menu - Hidden by default */}
  <div id="mobile-menu" class="hidden md:hidden absolute top-32 left-0 right-0 bg-white border-b border-black/5 flex flex-col p-6 gap-4 z-40 shadow-xl">
    {links.map((link) => (
      <a 
        href={link.href} 
        class="text-sm uppercase tracking-widest text-neutral-800 hover:text-blue-600 transition-colors duration-300 font-bold py-2 border-b border-black/5 last:border-0"
      >
        {link.name}
      </a>
    ))}
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
