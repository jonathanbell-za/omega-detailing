---
// Navbar.astro

const links = [
  { name: 'Home', href: '/' },
  { name: 'Pricing', href: '/pricing' },
  { name: 'Gallery', href: '/gallery' },
  { name: 'About', href: '/about' },
  { name: 'Book Now', href: 'https://wa.me/27605670893?text=Hi%20James!%20I%27d%20like%20to%20book%20a%20detailing%20session.', target: '_blank', rel: 'noopener noreferrer' },
  { name: 'My Cart', href: '/cart' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 backdrop-blur-md bg-white/80 border-b border-black/5 shadow-sm">
  <div class="max-w-7xl mx-auto px-6 flex flex-col justify-center">
    
    {/* Top Row: Center Logo (Desktop), Left Logo / Right Burger (Mobile) */}
    <div class="w-full flex items-center justify-between md:justify-center py-4 md:py-6 border-b border-black/5">
      <div class="w-8 md:hidden"></div> {/* Spacer for mobile alignment */}
      
      <a href="/" class="block group">
        <img 
          src="/logo.png" 
          alt="Omega Detailing Logo" 
          class="h-16 md:h-20 w-auto transition-transform duration-500 group-hover:scale-105" 
          loading="eager"
        />
      </a>
      
      {/* Mobile Menu Toggle Button */}
      <div class="md:hidden flex">
        <button id="mobile-menu-button" class="text-black p-2" aria-label="Toggle mobile menu">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>

    {/* Bottom Row: Desktop Navigation Menu */}
    <div class="hidden md:flex items-center justify-center gap-6 py-4">
      {links.map((link) => (
        <a 
          href={link.href} 
          target={link.target || null}
          rel={link.rel || null}
          class="inline-flex items-center justify-center px-6 py-2 bg-blue-600 hover:bg-neutral-900 text-white text-xs uppercase tracking-wider font-bold rounded-full border border-blue-600 hover:border-neutral-900 transition-all duration-300 shadow-sm"
        >
          {link.name}
        </a>
      ))}
    </div>
    
  </div>
  
  {/* Mobile Menu Panel - Hidden by default */}
  <div id="mobile-menu" class="hidden md:hidden absolute top-24 left-0 right-0 bg-white border-b border-black/5 flex flex-col p-6 gap-4 z-40 shadow-xl">
    {links.map((link) => (
      <a 
        href={link.href} 
        target={link.target || null}
        rel={link.rel || null}
        class="text-sm uppercase tracking-widest text-black hover:text-blue-600 transition-colors duration-300 font-bold py-2 border-b border-black/5 last:border-0"
      >
        {link.name}
      </a>
    ))}
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
