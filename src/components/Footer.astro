---
// Footer.astro
---

<footer id="contact" class="bg-black py-20 border-t border-neutral-900 text-white">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12">
    <!-- Brand -->
    <div class="space-y-6">
      <a href="/" class="text-3xl font-black tracking-tighter uppercase whitespace-nowrap">
        <span class="text-white">Omega</span><br>
        <span class="text-blue-500">Detailing</span>
      </a>
      <p class="text-neutral-500 max-w-sm leading-relaxed font-light">
        The pinnacle of automotive care. Elevate your driving experience with our premium restoration and protection perfection.
      </p>
    </div>

    <!-- Quick Links -->
    <div class="space-y-6">
      <h4 class="text-lg font-bold uppercase tracking-widest text-neutral-300">Fast Lane</h4>
      <ul class="space-y-4">
        <li>
          <a href="#services" class="text-neutral-500 hover:text-blue-500 transition-colors uppercase text-sm tracking-wider font-semibold">Services</a>
        </li>
        <li>
          <a href="#gallery" class="text-neutral-500 hover:text-blue-500 transition-colors uppercase text-sm tracking-wider font-semibold">Gallery</a>
        </li>
        <li>
          <a href="#about" class="text-neutral-500 hover:text-blue-500 transition-colors uppercase text-sm tracking-wider font-semibold">Our Studio</a>
        </li>
      </ul>
    </div>

    <!-- Contact Info -->
    <div class="space-y-6">
      <h4 class="text-lg font-bold uppercase tracking-widest text-neutral-300">Consultation</h4>
      <div class="space-y-4 text-neutral-500 text-sm font-light">
        <p class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          123 Apex Road, Motorsport Valley
        </p>
        <p class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.08-7.076-6.975l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          +1 (555) 867-5309
        </p>
        <p class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          booking@omegadetailing.com
        </p>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-20 pt-8 border-t border-neutral-900 flex flex-col md:flex-row items-center justify-between text-xs text-neutral-600 font-bold uppercase tracking-widest">
    <p>&copy; {new Date().getFullYear()} Omega Detailing. All rights reserved.</p>
    <div class="mt-4 md:mt-0 flex gap-6">
      <a href="#" class="hover:text-blue-500 transition-colors">Instagram</a>
      <a href="#" class="hover:text-blue-500 transition-colors">Facebook</a>
      <a href="#" class="hover:text-blue-500 transition-colors">YouTube</a>
    </div>
  </div>
</footer>
