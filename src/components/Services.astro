---
const services = [
  {
    title: 'Paint Correction',
    description: 'Masterful elimination of swirls, scratches, and oxidation to reveal a flawless, mirror-like finish that exceeds factory standards.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />`
  },
  {
    title: 'Ceramic Coating',
    description: 'Advanced 9H+ nanotechnology providing unmatched hydrophobicity, gloss, and multi-year protection against environmental contaminants.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />`
  },
  {
    title: 'Paint Protection Film (PPF)',
    description: 'Self-healing, invisible shield protecting your high-end vehicle from rock chips, scuffs, and road debris.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`
  },
  {
    title: 'Interior Restoration',
    description: 'Deep-cleaning and nourishment of premium leathers, alcantara, and carbon fiber trims for a concourse-ready cabin.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />`
  }
];
---

<section id="services" class="py-32 bg-neutral-950 relative">
  <!-- Subtle decorative glow -->
  <div class="absolute top-0 right-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tight mb-4">
        Our <span class="text-blue-500">Services</span>
      </h2>
      <p class="text-neutral-400 max-w-2xl mx-auto text-lg font-light">
        Uncompromising quality and attention to detail. We treat every vehicle as a masterpiece, utilizing state-of-the-art products and techniques.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map(service => (
        <div class="group relative bg-neutral-900 border border-neutral-800 p-10 hover:border-blue-500/50 transition-all duration-500 rounded-sm">
          <!-- Glass glare effect -->
          <div class="absolute inset-0 bg-gradient-to-br from-white/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative z-10">
            <div class="w-14 h-14 bg-neutral-950 border border-neutral-800 rounded-full flex items-center justify-center mb-6 group-hover:border-blue-500/50 group-hover:shadow-[0_0_15px_rgba(37,99,235,0.3)] transition-all duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-blue-500">
                <Fragment set:html={service.icon} />
              </svg>
            </div>
            
            <h3 class="text-2xl font-bold text-white mb-4 tracking-wide">{service.title}</h3>
            <p class="text-neutral-400 leading-relaxed font-light mb-6">
              {service.description}
            </p>
            
            <a href="#contact" class="inline-flex items-center text-sm font-bold uppercase tracking-widest text-blue-500 group-hover:text-blue-400">
              Learn More 
              <span class="ml-2 transform group-hover:translate-x-1 transition-transform duration-300">→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
