---
import ThreeBackground from './ThreeBackground.astro';
---

<section class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden bg-neutral-950">
  <!-- 3D Background layer -->
  <ThreeBackground />

  <!-- Overlay to ensure text readability -->
  <div class="absolute inset-0 bg-gradient-to-b from-neutral-950/40 via-neutral-950/20 to-neutral-950/90 z-10 pointer-events-none"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(37,99,235,0.15)_0,rgba(0,0,0,0)_50%)] z-10 pointer-events-none"></div>

  <!-- Content layer -->
  <div class="relative z-20 max-w-7xl mx-auto px-6 text-center lg:text-left flex flex-col lg:flex-row items-center w-full">
    <div class="lg:w-1/2 space-y-8 flex flex-col animate-fade-in-up">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-blue-500/30 bg-blue-900/20 backdrop-blur-sm self-center lg:self-start mb-4">
        <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
        <span class="text-blue-300 text-xs font-bold uppercase tracking-widest">Premium Care for Exotics</span>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-black text-white leading-[1.1] tracking-tight">
        Perfection in <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-white">Every Detail</span>
      </h1>
      
      <p class="text-lg md:text-xl text-neutral-400 max-w-xl mx-auto lg:mx-0 font-light">
        We specialize in the restoration, protection, and maintenance of high-end vehicles. Experience the ultimate showroom finish.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start pt-4">
        <a 
          href="#services" 
          class="inline-flex justify-center items-center py-4 px-8 bg-blue-600 hover:bg-blue-500 text-white font-bold uppercase tracking-wider rounded-sm transition-all duration-300 shadow-[0_0_20px_rgba(37,99,235,0.4)]"
        >
          Explore Services
        </a>
        <a 
          href="#gallery" 
          class="inline-flex justify-center items-center py-4 px-8 border border-neutral-700 hover:border-blue-500 text-white font-bold uppercase tracking-wider rounded-sm backdrop-blur-sm bg-white/5 hover:bg-blue-900/20 transition-all duration-300"
        >
          View Gallery
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
