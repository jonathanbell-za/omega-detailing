---
// Pricing.astro
const packages = [
  {
    id: 'essential',
    name: 'Essential',
    description: 'An essential cleaning package to maintain the freshness and clarity of your vehicle.',
    features: ['Exterior wash and dry', 'Interior vacuum and wipe down', 'Final detailed touches'],
    time: '1 to 1.5 hours',
    pricing: {
      hatchback: 300,
      suvSedan: 350,
      truckVan: 400
    },
    popular: false,
    icon: 'sparkles'
  },
  {
    id: 'premium',
    name: 'Premium',
    description: 'A deeper, more comprehensive package for detailed care of both interior and exterior.',
    features: ['Exterior wash and dry', 'Detailed exterior cleaning', 'Interior vacuum and wipe down', 'Detailed interior cleaning', 'Final detailed touches'],
    time: '2 to 2.5 hours',
    pricing: {
      hatchback: 650,
      suvSedan: 700,
      truckVan: 750
    },
    popular: false,
    icon: 'star'
  }
];

const protectionBundles = [
  {
    id: 'bundle-tier-1',
    name: 'Tier 1 Bundle',
    description: 'An entry-level exterior protection package designed to clean, restore, and protect. We perform a clay bar decontamination to remove embedded paint impurities, followed by a machine paint enhancement process that revives color and gloss. Finally, the paint is protected under a durable 1-year ceramic layer to repel dirt and ease maintenance.',
    features: [
      'Exterior detail',
      'Clay bar decontamination',
      'Paint enhancement',
      '1 Year ceramic coating'
    ],
    time: '5 to 6 hours',
    price: 2700,
    icon: 'shimmer',
    popular: false
  },
  {
    id: 'bundle-tier-2',
    name: 'Tier 2 Bundle',
    description: 'Our highly recommended standard bundle designed for serious paint restoration. We restore all faded plastic trim to deep black and perform clay bar decontamination, followed by a precise single-stage machine correction to eliminate up to 70% of swirls. Sealed under a premium 3-year ceramic coating for a deep candy gloss.',
    features: [
      'Exterior detail',
      'Trim restoration',
      'Clay bar decontamination',
      'One step paint correction',
      '3 Year ceramic coating'
    ],
    time: '1 day',
    price: 6500,
    icon: 'shield',
    popular: true
  },
  {
    id: 'bundle-tier-3',
    name: 'Tier 3 Bundle',
    description: 'The ultimate multi-day reset for your vehicle. We restore all plastic trim and clay bar the paint to remove bonded iron and tar contaminants, followed by an intensive two-step machine paint correction to eliminate up to 90% of defects. Locked in under our professional 5-year ceramic coating for maximum self-cleaning and mirror-like shine.',
    features: [
      'Exterior detail',
      'Trim restoration',
      'Clay bar decontamination',
      'Two step paint correction',
      '5 Year ceramic coating'
    ],
    time: '1 to 2 days',
    price: 9500,
    icon: 'crown',
    popular: false
  }
];

const detailingPackages = [
  {
    id: 'interior-detail',
    name: 'Interior Detail',
    description: 'A premium deep cleaning session where absolute attention is paid to every single surface. We meticulously vacuum, sanitize, and extract dirt from seats and carpets, while detailing every crack, crevice, and plastic trim piece to ensure a spotless, factory-fresh cabin environment.',
    features: [
      'Full vacuum on every surface',
      'Seat cleaning',
      'Carpet cleaning',
      'Deep cleaned plastics and trim',
      'Interior fragrance'
    ],
    time: '2 to 2.5 hours',
    price: 700,
    icon: 'armchair',
    popular: false
  },
  {
    id: 'exterior-detail',
    name: 'Exterior Detail',
    description: 'A meticulous multi-stage exterior decontamination wash process designed to lift road grime and paint impurities. We restore faded exterior plastic trim to a deep black finish and detail wheels to absolute perfection, revealing a high-gloss, clean paint surface.',
    features: [
      'Multi stage exterior wash',
      'Deep wheel detailing',
      'Trim restoration',
      'Final detailed touches'
    ],
    time: '2 to 2.5 hours',
    price: 600,
    icon: 'brush',
    popular: false
  }
];

const additionalOptions = [
  {
    id: 'paint-correction',
    name: 'Paint Correction',
    description: 'Our professional machine polishing service is designed to permanently remove paint imperfections, such as swirl marks, light scratches, hazing, and oxidation. By utilizing specialized dual-action polishers, micro-abrasive compounds, and premium foam or wool pads, we carefully level the clear coat to expose a flawless, mirror-like finish. This process restores the paint\'s original depth, clarity, and gloss, preparing the surface perfectly for high-end ceramic coatings.',
    options: [
      { label: 'One Step Correction (2-2.5h)', price: 2300 },
      { label: 'Two Step Correction (3-4h)', price: 3800 }
    ]
  },
  {
    id: 'ceramic-coating',
    name: 'Ceramic Coating',
    description: 'Experience the ultimate shield for your vehicle\'s paintwork with our state-of-the-art ceramic coatings. This liquid nanostructure chemically bonds to the clear coat, creating a sacrificial hydrophobic barrier that repels water, road grime, mud, and environmental contaminants. It offers superior resistance against UV damage, oxidation, light swirls, chemical etching, and bird droppings, while locking in an intense, mirror-like gloss.',
    options: [
      { label: '3 Month Coating', price: 400 },
      { label: '12 Month Coating', price: 1000 },
      { label: '3 Year Coating', price: 3500 },
      { label: '5 Year Coating', price: 5500 }
    ]
  },
  {
    id: 'upholstery-cleaning',
    name: 'Upholstery Cleaning',
    description: 'Deep extraction cleaning to remove stains, dirt, and odors from seats and floor mats.',
    options: [
      { label: 'Seat Cleaning (Per Seat)', price: 100 },
      { label: 'Floormat Cleaning (Per Mat)', price: 50 }
    ]
  },
  {
    id: 'paint-enhancement',
    name: 'Paint Enhancement',
    description: 'A cost-effective machine polishing service designed for vehicles with relatively healthy paint that just need an extra boost of shine. We perform a light, single-stage polishing process that targets very fine swirls, light wash marring, and dullness to dramatically enhance paint clarity and gloss.',
    price: 1200
  },
  {
    id: 'engine-bay-detail',
    name: 'Engine Bay Detail',
    description: 'A meticulous cleaning, degreasing, and dressing of the engine bay compartment to remove accumulated dirt, grime, and oil deposits, leaving a clean, factory-fresh finish.',
    price: 200
  }
];

const vehicleTypes = [
  { id: 'hatchback', label: 'Compact (Hatchback)' },
  { id: 'suvSedan', label: 'Standard (SUV / Sedan)' },
  { id: 'truckVan', label: 'Large (Van / Truck)' }
];

const icons = {
  droplets: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-4.038 0l-2.387.477a2 2 0 00-1.022.547l-3.859 3.859a2 2 0 000 2.828l1.172 1.172a2 2 0 002.828 0l.172-.172a4 4 0 00.586-1.03l.293-.733a4 4 0 011.485-2.228 4 4 0 012.228-1.485l.733-.293a4 4 0 001.03-.586l.172-.172a2 2 0 000-2.828l-1.172-1.172a2 2 0 00-2.828 0l-3.859 3.859z" /></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>`,
  home: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`,
  shimmer: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
  armchair: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" /></svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
  crown: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3L16 7L21 4L19 17H5L3 4L8 7L12 3Z M5 17L12 21L19 17" /></svg>`,
  sparkles: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 21L8.188 15.904L3 15L8.188 14.096L9 9L9.813 14.096L15 15L9.813 15.904ZM18.281 4.281L18 6L17.719 4.281L16 4L17.719 3.719L18 2L18.281 3.719L20 4L18.281 4.281ZM22.406 11.406L22 13L21.594 11.406L20 11L21.594 10.594L22 9L22.406 10.594L24 11L22.406 11.406Z" /></svg>`,
  brush: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 14l-6 6M20.25 11.25l-2.25 2.25m2.25-2.25a3.182 3.182 0 00-4.5 0l-10.5 10.5a1.5 1.5 0 01-2.12 0l-.88-.88a1.5 1.5 0 010-2.12l10.5-10.5a3.182 3.182 0 000-4.5l2.25-2.25a1.5 1.5 0 012.12 0l3.38 3.38a1.5 1.5 0 010 2.12zM3 21l3-3" /></svg>`
};
---

<section id="pricing" class="py-32 bg-neutral-50 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-24 space-y-6">

      <h2 class="text-6xl md:text-7xl font-black text-neutral-900 uppercase tracking-tighter leading-tight">
        CHOOSE YOUR <span class="text-blue-600">PACKAGE</span>
      </h2>

    </div>

    {/* Main Packages Header */}
    <div class="text-center mb-20">
       <h3 class="text-4xl font-black uppercase tracking-tight text-neutral-900 mb-4">Maintenance <span class="text-blue-600">Packages</span></h3>
       <div class="w-16 h-1 bg-blue-600 mx-auto"></div>
    </div>

    {/* Main Packages */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-32 max-w-5xl mx-auto">
      {packages.map((pkg) => (
        <div class={`package-card relative flex flex-col p-10 bg-white border-2 ${pkg.popular ? 'border-blue-600 shadow-xl shadow-blue-600/10' : 'border-neutral-200'} rounded-2xl transition-all duration-300 group overflow-hidden`} data-pkg={JSON.stringify(pkg)}>
          {pkg.popular && (
            <div class="absolute top-0 right-0 bg-blue-600 text-white text-[10px] font-black uppercase tracking-[0.2em] px-8 py-2 transform translate-x-[35%] translate-y-[100%] rotate-45">
              POPULAR
            </div>
          )}
          
          <div class="mb-10 md:min-h-[180px]">
            <div class="text-blue-600 mb-6 group-hover:scale-105 transition-transform" set:html={icons[pkg.icon]} />
            <h3 class="text-4xl font-black uppercase tracking-wider mb-4 border-b-2 border-neutral-100 pb-4">{pkg.name}</h3>
            <p class="text-neutral-600 font-light leading-relaxed text-sm">{pkg.description}</p>
          </div>

          <div class="space-y-6 mb-12">
            <div>
              <label class="text-[10px] font-black text-blue-600 uppercase tracking-widest mb-2 block">Vehicle Size</label>
              <select class="pkg-size-selector w-full bg-neutral-50 border border-neutral-200 p-4 text-neutral-900 font-bold uppercase tracking-widest text-xs outline-none focus:border-blue-600 transition-all rounded-xl appearance-none cursor-pointer">
                {vehicleTypes.map(type => (
                  <option value={type.id}>{type.label}</option>
                ))}
              </select>
            </div>
            
            <div class="flex justify-between items-end border-b-2 border-neutral-50 pb-4">
               <span class="text-neutral-400 text-xs font-bold uppercase tracking-widest">Total cost</span>
               <span class="current-price text-5xl font-black text-neutral-900 transition-colors group-hover:text-blue-600">R{pkg.pricing.hatchback}</span>
            </div>
          </div>

          <div class="mb-12 space-y-4 md:min-h-[180px]">
            <h4 class="text-xs font-black text-neutral-900 uppercase tracking-widest border-l-4 border-blue-600 pl-4 mb-6">What's Included</h4>
            <ul class="space-y-3">
              {pkg.features.map(f => (
                <li class="flex items-center gap-3 text-neutral-600 text-sm">
                  <div class="w-2 h-2 bg-blue-600 rounded-none transform rotate-45 flex-shrink-0"></div>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-auto space-y-6">
            <div class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 flex justify-between">
              <span>Duration</span>
              <span class="text-neutral-900">{pkg.time}</span>
            </div>
            <button class="add-package-to-cart w-full py-6 bg-blue-600 text-white font-black uppercase tracking-widest hover:bg-neutral-900 transition-all shadow-lg hover:shadow-neutral-900/20 rounded-xl">
              Add to Cart
            </button>
          </div>
        </div>
      ))}
    </div>

    {/* Exterior Protection Bundles Header */}
    <div class="text-center mb-20 mt-12">
       <h3 class="text-4xl font-black uppercase tracking-tight text-neutral-900 mb-4">Exterior <span class="text-blue-600">Protection Bundles</span></h3>
       <div class="w-16 h-1 bg-blue-600 mx-auto"></div>
    </div>

    {/* Exterior Protection Bundles Grid */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-32">
      {protectionBundles.map((pkg, idx) => (
        <div class={`package-card relative flex flex-col p-10 bg-white border-2 ${pkg.popular ? 'border-blue-600 shadow-xl shadow-blue-600/10' : 'border-neutral-200'} rounded-2xl transition-all duration-300 group overflow-hidden`} data-pkg={JSON.stringify(pkg)}>
          {pkg.popular && (
            <div class="absolute top-0 right-0 bg-blue-600 text-white text-[10px] font-black uppercase tracking-[0.2em] px-8 py-2 transform translate-x-[35%] translate-y-[100%] rotate-45">
              POPULAR
            </div>
          )}
          
          <div class="mb-10 md:min-h-[220px]">
            <div class="w-14 h-14 rounded-full bg-blue-600 text-white font-black text-xl flex items-center justify-center mb-6 group-hover:scale-105 transition-transform shadow-md shadow-blue-600/25">
              {idx + 1}
            </div>
            <h3 class="text-4xl font-black uppercase tracking-wider mb-4 border-b-2 border-neutral-100 pb-4">{pkg.name}</h3>
            <p class="text-neutral-600 font-light leading-relaxed text-sm">{pkg.description}</p>
          </div>

          <div class="space-y-6 mb-12">
            <div class="h-20">
              {/* Flat price, no size selector required */}
            </div>
            
            <div class="flex justify-between items-end border-b-2 border-neutral-50 pb-4">
               <span class="text-neutral-400 text-xs font-bold uppercase tracking-widest">Total cost</span>
               <span class="current-price text-5xl font-black text-neutral-900 transition-colors group-hover:text-blue-600">R{pkg.price}</span>
            </div>
          </div>

          <div class="mb-12 space-y-4 md:min-h-[240px]">
            <h4 class="text-xs font-black text-neutral-900 uppercase tracking-widest border-l-4 border-blue-600 pl-4 mb-6">What's Included</h4>
            <ul class="space-y-3">
              {pkg.features.map(f => (
                <li class="flex items-center gap-3 text-neutral-600 text-sm capitalize">
                  <div class="w-2 h-2 bg-blue-600 rounded-none transform rotate-45 flex-shrink-0"></div>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-auto space-y-6">
            <div class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 flex justify-between">
              <span>Duration</span>
              <span class="text-neutral-900">{pkg.time}</span>
            </div>
            <button class="add-package-to-cart w-full py-6 bg-blue-600 text-white font-black uppercase tracking-widest hover:bg-neutral-900 transition-all shadow-lg hover:shadow-neutral-900/20 rounded-xl">
              Add to Cart
            </button>
          </div>
        </div>
      ))}
    </div>

    {/* Interior and Exterior Detailing Header */}
    <div class="text-center mb-20 mt-12">
       <h3 class="text-4xl font-black uppercase tracking-tight text-neutral-900 mb-4">Interior & Exterior <span class="text-blue-600">Detailing</span></h3>
       <div class="w-16 h-1 bg-blue-600 mx-auto"></div>
    </div>

    {/* Interior and Exterior Detailing Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-32 max-w-5xl mx-auto">
      {detailingPackages.map((pkg) => (
        <div class={`package-card relative flex flex-col p-10 bg-white border-2 ${pkg.popular ? 'border-blue-600 shadow-xl shadow-blue-600/10' : 'border-neutral-200'} rounded-2xl transition-all duration-300 group overflow-hidden`} data-pkg={JSON.stringify(pkg)}>
          {pkg.popular && (
            <div class="absolute top-0 right-0 bg-blue-600 text-white text-[10px] font-black uppercase tracking-[0.2em] px-8 py-2 transform translate-x-[35%] translate-y-[100%] rotate-45">
              POPULAR
            </div>
          )}
          
          <div class="mb-10 md:min-h-[160px]">
            <div class="text-blue-600 mb-6 group-hover:scale-105 transition-transform" set:html={icons[pkg.icon]} />
            <h3 class="text-4xl font-black uppercase tracking-wider mb-4 border-b-2 border-neutral-100 pb-4">{pkg.name}</h3>
            <p class="text-neutral-600 font-light leading-relaxed text-sm">{pkg.description}</p>
          </div>

          <div class="space-y-6 mb-12">
            <div class="h-20">
              {/* Flat price, no size selector required */}
            </div>
            
            <div class="flex justify-between items-end border-b-2 border-neutral-50 pb-4">
               <span class="text-neutral-400 text-xs font-bold uppercase tracking-widest">Total cost</span>
               <span class="current-price text-5xl font-black text-neutral-900 transition-colors group-hover:text-blue-600">R{pkg.price}</span>
            </div>
          </div>

          <div class="mb-12 space-y-4 md:min-h-[240px]">
            <h4 class="text-xs font-black text-neutral-900 uppercase tracking-widest border-l-4 border-blue-600 pl-4 mb-6">What's Included</h4>
            <ul class="space-y-3">
              {pkg.features.map(f => (
                <li class="flex items-center gap-3 text-neutral-600 text-sm capitalize">
                  <div class="w-2 h-2 bg-blue-600 rounded-none transform rotate-45 flex-shrink-0"></div>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          <div class="mt-auto space-y-6">
            <div class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 flex justify-between">
              <span>Duration</span>
              <span class="text-neutral-900">{pkg.time}</span>
            </div>
            <button class="add-package-to-cart w-full py-6 bg-blue-600 text-white font-black uppercase tracking-widest hover:bg-neutral-900 transition-all shadow-lg hover:shadow-neutral-900/20 rounded-xl">
              Add to Cart
            </button>
          </div>
        </div>
      ))}
    </div>

    {/* Extras Header */}
    <div class="text-center mb-20 mt-12">
       <h3 class="text-4xl font-black uppercase tracking-tight text-neutral-900 mb-4"><span class="text-blue-600">Extras</span></h3>
       <div class="w-16 h-1 bg-blue-600 mx-auto"></div>
    </div>

    {/* Extras Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {additionalOptions.map((opt) => (
        <div class="option-card p-10 bg-white border border-neutral-200 hover:border-blue-600 rounded-2xl transition-all group flex flex-col shadow-sm" data-opt={JSON.stringify(opt)}>
          <div class="mb-6 md:min-h-[180px]">
            <h4 class="text-2xl font-black uppercase tracking-wider mb-2 text-neutral-900 group-hover:text-blue-600">{opt.name}</h4>
            {opt.description && <p class="text-neutral-700 font-medium text-xs leading-relaxed">{opt.description}</p>}
          </div>
          
          {opt.options ? (
            <div class="space-y-6 mb-10 flex-grow flex flex-col justify-between">
              <div class="space-y-3 md:min-h-[100px] flex flex-col justify-end">
                <select class="opt-type-selector w-full bg-neutral-50 border border-neutral-200 p-3 text-xs font-bold text-neutral-900 uppercase rounded-xl">
                  {opt.options.map((o, i) => (
                    <option value={i}>{o.label}</option>
                  ))}
                </select>
                {opt.id === 'upholstery-cleaning' && (
                  <div class="flex items-center gap-4 mt-2">
                    <label class="text-[10px] font-black text-neutral-400 uppercase tracking-widest">Qty:</label>
                    <select class="opt-qty-selector bg-neutral-50 border border-neutral-200 p-3 text-xs font-bold text-neutral-900 rounded-xl w-24 cursor-pointer outline-none focus:border-blue-600 transition-all">
                      {[1, 2, 3, 4, 5, 6, 7, 8].map(qty => (
                        <option value={qty}>{qty}</option>
                      ))}
                    </select>
                  </div>
                )}
              </div>
              <div class="text-4xl font-black text-blue-600 current-opt-price mt-auto">
                R{opt.options[0].price}
              </div>
            </div>
          ) : (
            <div class="mb-10 flex-grow flex flex-col justify-between">
              {opt.time && <p class="text-[10px] font-black text-neutral-400 uppercase tracking-[0.2em] mb-4">{opt.time}</p>}
              {opt.pricing && (
                 <div class="space-y-6 flex-grow flex flex-col justify-between">
                   <div class="space-y-3 md:min-h-[100px] flex flex-col justify-end">
                      <select class="opt-size-selector w-full bg-neutral-50 border border-neutral-200 p-3 text-[10px] text-neutral-900 font-bold uppercase tracking-widest outline-none rounded-xl">
                        {vehicleTypes.map(type => (
                          <option value={type.id}>{type.label}</option>
                        ))}
                      </select>
                   </div>
                   <div class="text-4xl font-black text-blue-600 current-opt-price mt-auto">R{opt.pricing.hatchback}</div>
                 </div>
              )}
              {opt.price && (
                 <div class="space-y-6 flex-grow flex flex-col justify-between">
                   <div class="space-y-3 md:min-h-[100px] flex flex-col justify-end">
                      {/* empty space to match heights */}
                   </div>
                   <div class="text-4xl font-black text-blue-600 current-opt-price mt-auto">R{opt.price}</div>
                 </div>
              )}
            </div>
          )}
          
          <button class="add-option-to-cart mt-auto w-full py-4 border-2 border-neutral-200 text-neutral-900 font-black uppercase tracking-widest hover:bg-blue-600 hover:text-white hover:border-blue-600 transition-all rounded-xl">
            Add to Cart
          </button>
        </div>
      ))}
    </div>


  </div>
</section>

{/* Premium Toast */}
<div id="toast" class="fixed bottom-10 right-10 z-[100] translate-y-20 opacity-0 transition-all duration-500 pointer-events-none">
  <div class="bg-blue-600 text-white px-10 py-5 font-black uppercase tracking-widest text-xs flex items-center gap-6 shadow-2xl border border-white/20 rounded-xl">
    <div class="p-2 bg-white/20 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
    </div>
    <div class="flex flex-col">
       <span class="text-[10px] opacity-70">Success</span>
       <span>Item Added to Cart</span>
    </div>
  </div>
</div>

<script>
  function updateCart(name, price) {
    const cart = JSON.parse(localStorage.getItem('omega-cart') || '[]');
    cart.push({ name, price: parseInt(price) });
    localStorage.setItem('omega-cart', JSON.stringify(cart));
    
    const toast = document.getElementById('toast');
    toast.classList.remove('translate-y-20', 'opacity-0');
    setTimeout(() => {
      toast.classList.add('translate-y-20', 'opacity-0');
    }, 4000);
  }

  // Main & Specialized Packages
  document.querySelectorAll('.package-card').forEach(card => {
    const pkgAttr = card.getAttribute('data-pkg');
    if (!pkgAttr) return;
    const pkg = JSON.parse(pkgAttr);
    const selector = card.querySelector('.pkg-size-selector');
    const priceDisplay = card.querySelector('.current-price');
    const btn = card.querySelector('.add-package-to-cart');

    selector?.addEventListener('change', (e) => {
      const size = e.target.value;
      const price = pkg.pricing[size];
      priceDisplay.textContent = `R${price}`;
    });

    btn?.addEventListener('click', () => {
      const sizeLabel = selector ? ` (${selector.options[selector.selectedIndex].text})` : '';
      const priceVal = selector ? pkg.pricing[selector.value] : pkg.price;
      updateCart(`${pkg.name}${sizeLabel}`, priceVal);
    });
  });

  // Additional Options
  document.querySelectorAll('.option-card').forEach(card => {
    const optAttr = card.getAttribute('data-opt');
    if (!optAttr) return;
    const opt = JSON.parse(optAttr);
    const typeSelector = card.querySelector('.opt-type-selector');
    const sizeSelector = card.querySelector('.opt-size-selector');
    const qtySelector = card.querySelector('.opt-qty-selector');
    const priceDisplay = card.querySelector('.current-opt-price');
    const btn = card.querySelector('.add-option-to-cart');

    function updatePrice() {
      if (!priceDisplay) return;
      if (opt.options) {
        const typeIdx = typeSelector.value;
        let price = opt.options[typeIdx].price;
        if (opt.id === 'upholstery-cleaning' && qtySelector) {
          price *= parseInt(qtySelector.value);
        }
        priceDisplay.textContent = `R${price}`;
      } else if (opt.pricing) {
        priceDisplay.textContent = `R${opt.pricing[sizeSelector.value]}`;
      }
    }

    typeSelector?.addEventListener('change', updatePrice);
    sizeSelector?.addEventListener('change', updatePrice);
    qtySelector?.addEventListener('change', updatePrice);

    btn?.addEventListener('click', () => {
      let finalName = opt.name;
      let finalPrice = opt.price || 0;

      if (opt.options) {
        const typeLabel = typeSelector.options[typeSelector.selectedIndex].text;
        let price = opt.options[typeSelector.value].price;
        if (opt.id === 'upholstery-cleaning' && qtySelector) {
          const qty = parseInt(qtySelector.value);
          finalName = `${opt.name}: ${typeLabel} (Qty: ${qty})`;
          finalPrice = price * qty;
        } else {
          finalName = `${opt.name}: ${typeLabel}`;
          finalPrice = price;
        }
      } else if (opt.pricing) {
        const sizeLabel = sizeSelector.options[sizeSelector.selectedIndex].text;
        finalName = `${opt.name} (${sizeLabel})`;
        finalPrice = opt.pricing[sizeSelector.value];
      }

      updateCart(finalName, finalPrice);
    });
  });
</script>

<style>
  #pricing {
    font-family: 'Inter', sans-serif;
  }
  
  select {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%232563eb' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 1rem center;
    background-repeat: no-repeat;
    background-size: 1.5em 1.5em;
  }

  .package-card:hover {
    box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.1), 0 0 50px rgba(37, 99, 235, 0.05);
  }
</style>
