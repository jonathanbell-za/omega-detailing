---
// InstagramCTA.astro
const INSTAGRAM_URL = 'https://www.instagram.com/omegavehicledetailing?igsh=Mmc2aGh1czB4Njkx';
---

<section class="ig-cta-section">
  <div class="ig-cta-inner">

    {/* Decorative background blobs */}
    <div class="ig-blob ig-blob-1"></div>
    <div class="ig-blob ig-blob-2"></div>

    {/* Icon */}
    <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="ig-icon-link" aria-label="Visit our Instagram">
      <div class="ig-icon-ring">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </div>
    </a>

    {/* Text content */}
    <div class="ig-cta-content">
      <p class="ig-eyebrow">Follow Along</p>
      <h2 class="ig-heading">See Our Work in Action</h2>
      <p class="ig-body">
        Watch real before-and-after transformations, detailing reels, and behind-the-scenes videos on our Instagram. Every car tells a story.
      </p>
      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="ig-cta-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        View @omegavehicledetailing
      </a>
    </div>

    {/* Stats strip */}
    <div class="ig-stats">
      <div class="ig-stat">
        <span class="ig-stat-icon">🎬</span>
        <span class="ig-stat-label">Detailing Reels</span>
      </div>
      <div class="ig-stat-divider"></div>
      <div class="ig-stat">
        <span class="ig-stat-icon">✨</span>
        <span class="ig-stat-label">Before & Afters</span>
      </div>
      <div class="ig-stat-divider"></div>
      <div class="ig-stat">
        <span class="ig-stat-icon">🚗</span>
        <span class="ig-stat-label">Real Results</span>
      </div>
    </div>

  </div>
</section>

<style>
  .ig-cta-section {
    position: relative;
    background: linear-gradient(135deg, #0f0f0f 0%, #1a1a2e 50%, #16213e 100%);
    padding: 100px 24px;
    overflow: hidden;
  }

  .ig-cta-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 32px;
    position: relative;
    z-index: 1;
  }

  /* Decorative blobs */
  .ig-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .ig-blob-1 {
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(193,53,132,0.25) 0%, transparent 70%);
    top: -80px;
    left: -100px;
  }
  .ig-blob-2 {
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(131,58,180,0.2) 0%, transparent 70%);
    bottom: -60px;
    right: -60px;
  }

  /* Icon */
  .ig-icon-link {
    display: block;
    text-decoration: none;
  }

  .ig-icon-ring {
    width: 88px;
    height: 88px;
    border-radius: 24px;
    background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    box-shadow: 0 8px 40px rgba(220, 39, 67, 0.45);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ig-icon-link:hover .ig-icon-ring {
    transform: scale(1.08) rotate(-4deg);
    box-shadow: 0 16px 56px rgba(220, 39, 67, 0.6);
  }

  /* Text */
  .ig-eyebrow {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #e1306c;
    margin: 0;
  }

  .ig-heading {
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .ig-body {
    font-size: 16px;
    line-height: 1.75;
    color: rgba(255,255,255,0.6);
    max-width: 520px;
    margin: 0;
    font-weight: 300;
  }

  .ig-cta-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  /* CTA Button */
  .ig-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
    padding: 14px 28px;
    border-radius: 50px;
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    background-size: 200% 200%;
    color: #fff;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background-position 0.4s ease;
    box-shadow: 0 4px 24px rgba(220, 39, 67, 0.4);
    animation: ig-gradient-shift 4s ease infinite alternate;
  }

  .ig-cta-btn:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 10px 36px rgba(220, 39, 67, 0.55);
  }

  @keyframes ig-gradient-shift {
    0%   { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }

  /* Stats strip */
  .ig-stats {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 20px 36px;
    border-radius: 16px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(10px);
    flex-wrap: wrap;
    justify-content: center;
  }

  .ig-stat {
    display: flex;
    align-items: center;
    gap: 10px;
    color: rgba(255,255,255,0.75);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ig-stat-icon {
    font-size: 18px;
  }

  .ig-stat-divider {
    width: 1px;
    height: 24px;
    background: rgba(255,255,255,0.15);
  }

  @media (max-width: 480px) {
    .ig-stat-divider { display: none; }
    .ig-stats { gap: 16px; }
  }
</style>
