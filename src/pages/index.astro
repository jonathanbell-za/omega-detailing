---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';

---

<Layout title="Omega Detailing | South African Premium Mobile Detailing">
	<Navbar />
	<main class="bg-white font-sans">
		<Hero />
	</main>
	<footer id="contact" class="bg-neutral-100 py-24 border-t border-neutral-200 text-neutral-900">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-16">
    <!-- Brand -->
    <div class="space-y-6">
      <a href="/" class="text-3xl font-black tracking-tighter uppercase whitespace-nowrap block">
        <span class="text-black">Omega</span>
        <span class="text-blue-600">Detailing</span>
      </a>
      <p class="text-neutral-500 max-w-sm leading-relaxed font-light">
        South Africa's premier mobile vehicle detailing company. Specialized car care delivered directly to your doorstep.
      </p>
    </div>

    <!-- Quick Links -->
    <div class="space-y-6">
      <h4 class="text-lg font-bold uppercase tracking-widest text-neutral-900 border-b-2 border-blue-600 pb-2 inline-block">Navigation</h4>
      <ul class="space-y-4">
        <li>
          <a href="/" class="text-neutral-600 hover:text-blue-600 transition-colors uppercase text-xs tracking-widest font-black">Home</a>
        </li>
        <li>
          <a href="/pricing" class="text-neutral-600 hover:text-blue-600 transition-colors uppercase text-xs tracking-widest font-black">Pricing</a>
        </li>
        <li>
          <a href="/about" class="text-neutral-600 hover:text-blue-600 transition-colors uppercase text-xs tracking-widest font-black">About Us</a>
        </li>
        <li>
          <a href="/book-now" class="text-neutral-600 hover:text-blue-600 transition-colors uppercase text-xs tracking-widest font-black">Book Now</a>
        </li>
      </ul>
    </div>

    <!-- Contact Info -->
    <div class="space-y-6">
      <h4 class="text-lg font-bold uppercase tracking-widest text-neutral-900 border-b-2 border-blue-600 pb-2 inline-block">Consultation</h4>
      <div class="space-y-4 text-neutral-700 text-sm font-medium">
        <p class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-blue-600">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
          James Bell
        </p>
        <p class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-blue-600">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.08-7.076-6.975l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <a href="tel:0605670893" class="hover:text-blue-600 transition-colors">060 567 0893</a>
        </p>
        <p class="flex items-center gap-3">
           <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          <a href="https://instagram.com/omegavehicledetailing" target="_blank" class="hover:text-blue-600 transition-colors italic">@omegavehicledetailing</a>
        </p>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-20 pt-10 border-t border-neutral-200 flex flex-col md:flex-row items-center justify-between text-[10px] text-neutral-400 font-black uppercase tracking-[0.4em]">
    <p>&copy; {new Date().getFullYear()} Omega Detailing. Quality Mobile Car Care.</p>
    <div class="mt-4 md:mt-0 flex gap-6">
      <a href="https://instagram.com/omegavehicledetailing" class="hover:text-blue-600 transition-all">Instagram</a>
      <span class="text-neutral-200">|</span>
      <span>South Africa</span>
    </div>
  </div>
</footer>
</Layout>
